# Flint — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to source control.

# -----------------------------------------------------------------------
# Supabase (required)
# Get these from your Supabase project dashboard → Settings → API
# -----------------------------------------------------------------------

# Public URL of your Supabase project (safe to expose to the client)
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co

# Public anon key (safe to expose — all access governed by RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service role key (SERVER-SIDE ONLY — never expose to client)
# Used for admin operations such as creating matches and validating receipts
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# -----------------------------------------------------------------------
# Google / Gemini AI (optional — for prompt analysis & profile summaries)
# -----------------------------------------------------------------------
GEMINI_API_KEY=<your-gemini-api-key>

# -----------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------

# Base URL used for auth redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Comma-separated ISO country codes allowed at signup / profile (default US,CA)
NEXT_PUBLIC_LAUNCH_COUNTRY_CODES=US,CA

# -----------------------------------------------------------------------
# SheerID (student verification — server-side only; wire when integrating)
# -----------------------------------------------------------------------
# SHEERID_API_KEY=
# SHEERID_PROGRAM_ID=
# SHEERID_WEBHOOK_SECRET=
