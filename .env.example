# Flint — Environment Variables
# Copy this file to .env.local and fill in real values.
# Never commit .env.local to source control.

# -----------------------------------------------------------------------
# Supabase (required)
# Get these from your Supabase project dashboard → Settings → API
# -----------------------------------------------------------------------

# Expo uses EXPO_PUBLIC_ prefix for client-visible env vars.
# These are bundled into the app — safe because access is governed by RLS.
EXPO_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=<your-anon-key>

# Service role key — SERVER-SIDE ONLY, never expose to the client.
# Used for admin scripts, Edge Functions, and test data seeding.
SUPABASE_SERVICE_ROLE_KEY=<your-service-role-key>

# -----------------------------------------------------------------------
# App config
# -----------------------------------------------------------------------

# Base URL used for auth redirects (web / magic link flows)
EXPO_PUBLIC_APP_URL=http://localhost:8081

# Comma-separated ISO country codes allowed at signup (default US,CA)
EXPO_PUBLIC_LAUNCH_COUNTRY_CODES=US,CA

# -----------------------------------------------------------------------
# Google / Gemini AI (optional — for prompt analysis & profile summaries)
# -----------------------------------------------------------------------
GEMINI_API_KEY=<your-gemini-api-key>

# -----------------------------------------------------------------------
# SheerID (student verification — server-side only; wire when integrating)
# -----------------------------------------------------------------------
# SHEERID_API_KEY=
# SHEERID_PROGRAM_ID=
# SHEERID_WEBHOOK_SECRET=
