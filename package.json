{
  "name": "flint",
  "version": "0.1.0",
  "private": true,
  "description": "Flint — compatibility-first dating app. Strike something real.",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "type-check": "tsc --noEmit",
    "lint": "eslint . --ext .ts,.tsx",
    "supabase:start": "supabase start",
    "supabase:stop": "supabase stop",
    "supabase:reset": "supabase db reset",
    "supabase:types": "supabase gen types typescript --local > src/types/database.ts",
    "supabase:migrate": "supabase db push",
    "db:validate": "supabase db reset && tsc --noEmit",
    "db:validate:full": "supabase db reset && supabase gen types typescript --local > src/types/database.ts && tsc --noEmit"
  },
  "dependencies": {
    "@react-native-async-storage/async-storage": "^2.1.2",
    "@supabase/supabase-js": "^2.49.4",
    "expo": "~53.0.0",
    "expo-router": "~4.0.0",
    "expo-secure-store": "~14.0.0",
    "expo-status-bar": "~2.2.0",
    "react": "18.3.1",
    "react-native": "0.76.7",
    "react-native-safe-area-context": "^4.14.0",
    "react-native-screens": "^4.4.0"
  },
  "devDependencies": {
    "@babel/core": "^7.25.0",
    "@types/react": "~18.3.12",
    "supabase": "^2.22.6",
    "typescript": "^5.8.3"
  }
}
